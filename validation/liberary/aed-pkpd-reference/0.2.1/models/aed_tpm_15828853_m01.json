  "raw": {
    "citation": "Battino 2005 15828853",
    "population": "[Children not receiving enzyme inducers] N: 38 AGE: 9.3 ± 4.5 WT: 34.3 ± 16.7 [Children receiving enzyme inducers] N: 32 AGE: 10.4 ± 5.4 WT: 37.3 ± 21.3 [Adults not receiving enzyme inducers] N: 38 AGE: 35.8 ± 12.2 WT: 67.8 ± 16.3 [Adults receiving enzyme inducers] N: 32 AGE: 37.0 ± 11.5 WT: 67.6 ± 15.0",
    "model_type": "PK",
    "objective": "“To compare the steady-state pharmacokinetics of topiramate in a large population of children and adults with epilepsy in a therapeutic drug monitoring setting”",
    "covariates": "Tested: Age, topiramate dose, sex and enzyme inducer comedication Included: Age, topiramate dose, enzyme inducer comedication",
    "observations": "Topiramate CL/F is highest in young children and decreases progressively with age until puberty, presumably due to age-dependent changes in the rate of drug metabolism. Younger patients require higher dosages to achieve serum topiramate concentrations comparable with those found in older children and adults. Enzyme-inducing comedication decreases serum topiramate concentration by approximately one-half and one-third in children and adults, respectively. The multiple regression models applied do not allow the quantification of inter-individual variability but still provide a good understanding of parameter-covariate relationships.",
    "dose": "Steady-state oral doses in patients",
    "structure": "CL/F derived from Css Multiple regression model to quantify the relative contribution of each covariate to variability in topiramate CL/F",
    "equations": "CL/F was derived as follows: CL/F (mL/h/kg) = Topiramate daily dose (mg/kg)/[Css (mg/mL) × 24h] Multiple regression models: Pooled data: CL/F = theta1 + theta2 × comedication – theta3 × age + theta4 × dose CL/F = 33.8 + 28.6 × comedication − 0.61 × age + 3.0 × dose Children: CL/F = theta1 + theta2 × comedication – theta3 × age + theta4 × dose CL/F = 41.6 + 42.0 × comedication − 2.5 × age + 4.1 × dose Adults: CL/F = theta1 + theta2 × comedication CL/F = 28.4 + 17.7 × comedication",
    "parameter_values": "Pooled data: Theta1 = 33.8 Theta2 = 28.6 Theta3 = 0.61 Theta4 = 3.0 Children: Theta1 = 41.6 Theta2 = 42.0 Theta3 = 2.5 Theta4 = 4.1 Adults: Theta1 = 28.4 Theta2 = 17.7",
    "validation": "No / No"
  },
