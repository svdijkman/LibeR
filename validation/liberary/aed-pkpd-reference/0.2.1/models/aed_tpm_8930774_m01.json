    "citation": "Doose 1996 8930774",
    "population": "[Safety and acceptability study] N: 28 AGE: 29.5 (21-41) WT: 71.2 (63.5-88.5) [Food effect study] N: 36 AGE: 25 (19-39) + 24.9 (21-41) WT: 5.3 (68.0-82.6) + 73.5 (64.0-86.2)",
    "model_type": "PK",
    "objective": "“Evaluate the safety and pharmacokinetics characteristics of topiramate” and the effect of food on the pharmacokinetics of topiramate",
    "covariates": "Dose, food effect",
    "observations": "AUC and Cmax were found to increase linearly with dose but the increase was greater-than-proportional possibily due to saturable binding to erythrocytes. Food effect showed a decrease in the rate of absorption (longer Tmax and slightly lower Cmax) but not on the extent of absorption with similar AUC between fasted and fed individuals. No model developed, limited possibility to extrapolate the findings.",
    "dose": "Single oral dose in healthy subjects",
    "structure": "Simplified PK",
    "equations": "if(DOSE==100) CL/F=theta1 if(DOSE==200) CL/F=theta2 if(DOSE==400) CL/F=theta3 if(DOSE==800) CL/F=theta4 if(DOSE==1200) CL/F=theta5 Css=DOSE/(CL*Tau) DOSE is the dose (mg; per dosing interval) Tau is the dosing interval (hours)",
    "parameter_values": "theta1=36.1 theta2=28.5 theta3=25.8 theta4=23.2 theta5=22.5",
    "validation": "No / No"
  },
