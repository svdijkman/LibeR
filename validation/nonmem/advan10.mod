$PROBLEM LibeR ADVAN10 Michaelis-Menten prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan10.dat
$SUBROUTINES ADVAN10 TRANS1 TOL=9
$PK
VM=THETA(1)*EXP(ETA(1))
KM=THETA(2)
S1=THETA(3)
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 20 FIX
$THETA 50 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan10.tab
