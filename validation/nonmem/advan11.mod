$PROBLEM LibeR ADVAN11 prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan11.dat
$SUBROUTINES ADVAN11 TRANS4
$PK
CL=THETA(1)*EXP(ETA(1))
V1=THETA(2)
Q2=THETA(3)
V2=THETA(4)
Q3=THETA(5)
V3=THETA(6)
S1=V1
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 2 FIX
$THETA 20 FIX
$THETA 1 FIX
$THETA 10 FIX
$THETA 0.5 FIX
$THETA 30 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan11.tab
