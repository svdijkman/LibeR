$PROBLEM LibeR ADVAN12 prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan12.dat
$SUBROUTINES ADVAN12 TRANS4
$PK
KA=THETA(1)
CL=THETA(2)*EXP(ETA(1))
V2=THETA(3)
Q3=THETA(4)
V3=THETA(5)
Q4=THETA(6)
V4=THETA(7)
S2=V2
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 1.5 FIX
$THETA 2 FIX
$THETA 20 FIX
$THETA 1 FIX
$THETA 10 FIX
$THETA 0.5 FIX
$THETA 30 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan12.tab
