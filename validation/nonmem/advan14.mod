$PROBLEM LibeR ADVAN14 stiff/nonstiff prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan14.dat
$SUBROUTINES ADVAN14 TOL=9
$MODEL COMP=(FAST DEFDOSE) COMP=(SLOW DEFOBSERVATION)
$PK
KFAST=THETA(1)*EXP(ETA(1))
KSLOW=THETA(2)
S2=1
$DES
DADT(1)=-KFAST*A(1)
DADT(2)=KFAST*A(1)-KSLOW*A(2)
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 1000 FIX
$THETA 1 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan14.tab
