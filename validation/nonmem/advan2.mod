$PROBLEM LibeR ADVAN2 prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan2.dat
$SUBROUTINES ADVAN2 TRANS2
$PK
KA=THETA(1)
CL=THETA(2)*EXP(ETA(1))
V=THETA(3)
S2=V
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 1.5 FIX
$THETA 2 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan2.tab
