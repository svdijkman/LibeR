$PROBLEM LibeR ADVAN6 prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan6.dat
$SUBROUTINES ADVAN6 TOL=9
$MODEL COMP=(CENTRAL)
$PK
K=THETA(1)*EXP(ETA(1))
S1=THETA(2)
$DES
DADT(1)=-K*A(1)
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 0.4 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan6.tab
