$PROBLEM LibeR ADVAN7 real-eigenvalue prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan7.dat
$SUBROUTINES ADVAN7 TRANS1
$MODEL
COMP=(CENTRAL DEFDOSE DEFOBSERVATION)
COMP=(PERIPH)
$PK
K10=THETA(1)*EXP(ETA(1))
K12=THETA(2)
K21=THETA(3)
S1=THETA(4)
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 0.2 FIX
$THETA 0.1 FIX
$THETA 0.05 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan7.tab
