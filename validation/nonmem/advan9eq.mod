$PROBLEM LibeR ADVAN9 equilibrium-compartment prediction validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA advan9eq.dat
$SUBROUTINES ADVAN9 TOL=9
$MODEL
COMP=(CENTRAL DEFDOSE DEFOBSERVATION)
COMP=(BOUND EQUILIBRIUM)
$PK
K=THETA(1)*EXP(ETA(1))
BIND=THETA(2)
S1=THETA(3)
$AESINITIAL
A(2)=A(1)/(1+BIND)
$DES
DADT(1)=-K*A(2)
$AES
E(2)=A(2)-A(1)/(1+BIND)
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 0.4 FIX
$THETA 1 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=advan9eq.tab
