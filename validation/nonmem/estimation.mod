$PROBLEM LibeR FOCEI estimation validation
$INPUT ID TIME EVID AMT CMT DV MDV
$DATA estimation.dat IGNORE=@
$SUBROUTINES ADVAN1 TRANS2
$PK
CL=THETA(1)*EXP(ETA(1))
V=THETA(2)
S1=V
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA (0.1,1,10)
$THETA 20 FIX
$OMEGA 0.1 FIX
$SIGMA 0.04 FIX
$ESTIMATION METHOD=COND INTERACTION MAXEVAL=999 NOABORT SIGL=10 NSIG=3
$COVARIANCE PRINT=E
$TABLE ID TIME EVID IPRED ETA(1) NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=estimation.tab
