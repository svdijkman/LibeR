$PROBLEM LibeR RATE=-1 modelled infusion validation
$INPUT ID TIME EVID AMT RATE CMT DV MDV
$DATA rate1.dat
$SUBROUTINES ADVAN1 TRANS2
$PK
CL=THETA(1)*EXP(ETA(1))
V=THETA(2)
R1=THETA(3)
S1=V
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 2 FIX
$THETA 20 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT RATE CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=rate1.tab
