$PROBLEM LibeR steady-state intermittent infusion validation
$INPUT ID TIME EVID AMT RATE CMT SS II DV MDV
$DATA ssinfusion.dat
$SUBROUTINES ADVAN1 TRANS2
$PK
CL=THETA(1)*EXP(ETA(1))
V=THETA(2)
S1=V
$ERROR
IPRED=F
Y=F+EPS(1)
$THETA 2 FIX
$THETA 20 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 NOABORT
$TABLE ID TIME EVID AMT CMT IPRED NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=ssinfusion.tab
