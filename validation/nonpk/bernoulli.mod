$PROBLEM LibeRation non-PK validation: Bernoulli likelihood
$INPUT ID TIME DV
$DATA bernoulli.dat
$PRED
 P = 0.7+0*ETA(1)
 LIKE = 0
 IF (DV.EQ.1) LIKE = P
 IF (DV.EQ.0) LIKE = 1-P
 Y = LIKE
$THETA 0 FIX
$OMEGA 0 FIX
$ESTIMATION METHOD=COND LAPLACIAN LIKELIHOOD MAXEVAL=0 PRINT=0
$TABLE ID TIME LIKE NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=bernoulli.tab
