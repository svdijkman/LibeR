$PROBLEM LibeRation non-PK validation: observed Markov likelihood
$INPUT ID TIME DV FIRST PREV
$DATA markov.dat
$PRED
 DUMMY = 0*ETA(1)
 LIKE = 0
 IF (FIRST.EQ.1.AND.DV.EQ.0) LIKE = 0.6
 IF (FIRST.EQ.1.AND.DV.EQ.1) LIKE = 0.4
 IF (FIRST.EQ.0.AND.PREV.EQ.0.AND.DV.EQ.0) LIKE = 0.8
 IF (FIRST.EQ.0.AND.PREV.EQ.0.AND.DV.EQ.1) LIKE = 0.2
 IF (FIRST.EQ.0.AND.PREV.EQ.1.AND.DV.EQ.0) LIKE = 0.3
 IF (FIRST.EQ.0.AND.PREV.EQ.1.AND.DV.EQ.1) LIKE = 0.7
 Y = LIKE
$THETA 0 FIX
$OMEGA 0 FIX
$ESTIMATION METHOD=COND LAPLACIAN LIKELIHOOD MAXEVAL=0 PRINT=0
$TABLE ID TIME FIRST PREV LIKE NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=markov.tab
