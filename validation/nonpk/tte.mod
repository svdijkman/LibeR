$PROBLEM LibeRation non-PK validation: interval TTE likelihood
$INPUT ID TIME DV DT
$DATA tte.dat
$PRED
 HAZ = 0.2+0*ETA(1)
 LIKE = EXP(-HAZ*DT)
 IF (DV.EQ.1) LIKE = LIKE*HAZ
 Y = LIKE
$THETA 0 FIX
$OMEGA 0 FIX
$ESTIMATION METHOD=COND LAPLACIAN LIKELIHOOD MAXEVAL=0 PRINT=0
$TABLE ID TIME DT LIKE NOPRINT ONEHEADER FORMAT=s1PE15.8 FILE=tte.tab
